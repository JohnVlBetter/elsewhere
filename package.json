{
  "name": "ai-interactive-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck",
    "test": "node --require ./scripts/vite-windows-net-use-shim.cjs ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node --require ./scripts/vite-windows-net-use-shim.cjs ./node_modules/vitest/vitest.mjs",
    "test:coverage": "node scripts/v8-coverage-gate.cjs",
    "typecheck": "node scripts/next-env-routes.cjs apps/web/next-env.d.ts && tsc --noEmit -p tsconfig.base.json --pretty false",
    "lint": "npm run typecheck",
    "ci": "npm run lint && npm test && npm run test:coverage && npm run web:build && npm run web:smoke",
    "ci:e2e": "npm run e2e",
    "cli": "node --no-warnings=ExperimentalWarning --experimental-transform-types --experimental-loader ./scripts/extensionless-ts-loader.mjs apps/cli/src/main.ts",
    "web:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-web.ps1",
    "web:dev": "node --require ./scripts/sandbox-node-compat.cjs ./scripts/next-dev-in-process.cjs",
    "web:build": "node --require ./scripts/sandbox-node-compat.cjs ./scripts/next-build.cjs",
    "web:smoke": "npm run web:build && node --require ./scripts/sandbox-node-compat.cjs ./scripts/web-smoke.cjs",
    "e2e:install": "playwright install chromium",
    "e2e": "node --require ./scripts/sandbox-node-compat.cjs ./node_modules/@playwright/test/cli.js test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "minisearch": "^7.2.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
